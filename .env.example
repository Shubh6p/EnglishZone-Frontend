# ===========================================
# ENGLISH ZONE - FRONTEND ENVIRONMENT VARIABLES
# ===========================================

# 1. API Connection
# -------------------------------------------
# The base URL pointing to your backend server
# If running locally, it is usually http://localhost:5000/api/v1
# In production, change this to your deployed backend URL (e.g., https://api.englishzone.com/api/v1)
VITE_API_URL="http://localhost:5000/api/v1"

# 2. Demo Mode
# -------------------------------------------
# Set to 'true' to show the "Autofill Credentials" box on the login screen
# Set to 'false' in production so users must type their actual passwords
VITE_DEMO_MODE="true"
